# Daily signal email configuration — see README "Daily signal email" for setup.
# Copy this file to .env (gitignored — NEVER commit a real .env) and fill in.
# The systemd predict service reads it via:
#   EnvironmentFile=%h/projects/twopercent/.env
# Note: no inline comments after values — the parser takes the whole value.

# Common: recipient(s), comma-separated for more than one, and the From address.
TWOPERCENT_EMAIL_TO=you@example.com
TWOPERCENT_EMAIL_FROM=onboarding@resend.dev

# --- Transport 1 (recommended): Resend HTTP API -------------------------------
# A scoped, send-only, revocable API key from https://resend.com (free tier).
# No personal account credential is ever stored on this box.
TWOPERCENT_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Transport 2 (fallback): generic SMTP over STARTTLS ------------------------
# For a DEDICATED sending account only — never a personal credential.
# Ignored (with a warning) when TWOPERCENT_RESEND_API_KEY is also set.
#TWOPERCENT_SMTP_HOST=smtp.example.com
#TWOPERCENT_SMTP_PORT=587
#TWOPERCENT_SMTP_USER=sender@example.com
#TWOPERCENT_SMTP_PASSWORD=service-account-password
